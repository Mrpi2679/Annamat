    "preview": "vite preview",
    "postinstall": "node -e \"try{require('fs').copyFileSync('.env.example','.env')}catch(e){}\""
  },
  "dependencies": {
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.3.0",
    "mongoose": "^8.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^10.0.3",
    "vite": "^8.0.16"
  },
  "vercel": {
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "devCommand": "npm run dev"
  }
