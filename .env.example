# Get your free MongoDB Atlas URI at https://www.mongodb.com/atlas
# Replace <username>, <password>, and <cluster> with your details
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/annamat?retryWrites=true&w=majority

# Use any random string here (e.g., a generated UUID)
JWT_SECRET=change_this_to_a_random_secret_string
